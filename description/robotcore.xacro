<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  >

    
    <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.15"/>
  </joint>

  <link name="base_link">
    <visual><geometry><box size="0.5 0.4 0.15"/></geometry></visual>
    <collision><geometry><box size="0.5 0.4 0.15"/></geometry></collision>
    <inertial><mass value="20"/>
      <inertia ixx="0.2" iyy="0.2" izz="0.3" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Left Wheel -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.13 0.22 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel">
    <visual><geometry><cylinder length="0.05" radius="0.1"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.1"/></geometry></collision>
    <inertial><mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

<!-- Right Wheel -->

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.13 -0.22 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="right_wheel">
    <visual><geometry><cylinder length="0.05" radius="0.1"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.1"/></geometry></collision>
    <inertial><mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  

<!-- Caster Wheel back -->

    <joint name="caster_back_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_back"/>
        <origin xyz="-0.15 0 -0.10"/>
    </joint>
    <link name="caster_back">
        <visual><geometry><sphere length="0.05" radius="0.05"/></geometry></visual>
        <collision><geometry><sphere length="0.05" radius="0.05"/></geometry></collision>
        <inertial><mass value="1"/>
            <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <gazebo reference="caster_back">
        <mu1 value= "0.001"/>
        <mu2 value="0.001"/>
        
        </gazebo>
    

  <!-- Laser Scanner -->

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.2 0 0.1"/>
  </joint>
  <link name="laser_link">
    <visual><geometry><cylinder length="0.05" radius="0.05"/></geometry></visual>
  </link>

</robot>